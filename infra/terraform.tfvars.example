# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.

# --- required ---
github_owner = "your-github-username"

# --- AWS (defaults are fine for the challenge) ---
aws_region   = "us-east-1"
project_name = "cloudmart"

# --- OpenAI customer-support assistant ---
# Run: node scripts/bootstrap-openai-assistant.mjs  (prints the assistant id)
openai_api_key      = "sk-..."
openai_assistant_id = "asst_..."

# --- Azure sentiment analysis (optional) ---
enable_azure          = false
# azure_location        = "eastus"
# azure_subscription_id = "00000000-0000-0000-0000-000000000000"

# --- GCP BigQuery analytics (optional) ---
enable_gcp     = false
# gcp_project_id = "your-gcp-project-id"
# gcp_region     = "US"
