# CloudMart backend environment (copy to .env for local dev)
PORT=5000
AWS_REGION=us-east-1

# Local dev only. In EKS these come from the Terraform-managed Kubernetes Secret
# (see infra/aws/k8s_secret.tf) and IRSA supplies AWS credentials automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Amazon Bedrock agent (Terraform outputs: agent_id / agent_alias_id)
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=

# OpenAI assistant (scripts/bootstrap-openai-assistant.mjs prints the assistant id)
OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=

# Azure Text Analytics (Terraform outputs when enable_azure=true)
AZURE_ENDPOINT=
AZURE_API_KEY=
